---
import { Icon } from 'astro-icon/components';

const links = [
  { label: "Spotify", href: "https://open.spotify.com/artist/4e0iuPsdmWHXPw1UQV6FQq", icon: "simple-icons:spotify" },
  { label: "Apple Music", href: "https://music.apple.com/us/artist/slim-cognito/6777271941", icon: "simple-icons:applemusic" },
  { label: "Instagram", href: "https://www.instagram.com/slimcognitoband", icon: "simple-icons:instagram" },
  { label: "YouTube", href: "https://www.youtube.com/@SlimCognitoBand", icon: "simple-icons:youtube" },
  { label: "TikTok", href: "https://www.tiktok.com/@slimcognitoband", icon: "simple-icons:tiktok" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Slim Cognito — Links" />
    <title>Slim Cognito — Links</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main>
      <div class="noise"></div>
      <div class="container">
        <a href="/" class="back">← Back</a>
        <h1>Slim Cognito</h1>
        <nav class="links">
          {links.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer">
              <Icon name={link.icon} />
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </main>
  </body>
</html>

<style>
  @font-face {
    font-family: 'DeaconFlock';
    src: url('/fonts/DeaconFlock.ttf') format('truetype');
    font-weight: normal;
    font-style: normal;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    height: 100%;
  }

  body {
    background: #0a0a0a;
    color: #f0f0f0;
    font-family: 'Inter', sans-serif;
    font-weight: 300;
  }

  main {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow: hidden;
  }

  .noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    pointer-events: none;
    opacity: 0.4;
  }

  .container {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 480px;
    padding: 3rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .back {
    align-self: flex-start;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #555;
    text-decoration: none;
    transition: color 0.2s;
  }

  .back:hover {
    color: #9b6fc4;
  }

  h1 {
    font-family: 'DeaconFlock', sans-serif;
    font-size: clamp(2.5rem, 10vw, 4rem);
    letter-spacing: 0.05em;
    color: #fff;
    text-shadow: 0 0 80px rgba(110, 40, 180, 0.5), 0 0 20px rgba(110, 40, 180, 0.3);
    text-align: center;
  }

  .links {
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 0.75rem;
  }

  .links a {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    padding: 1rem;
    border: 1px solid #3a1a5c;
    border-radius: 2px;
    color: #ccc;
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-align: center;
    transition: border-color 0.2s, color 0.2s, background 0.2s, box-shadow 0.2s;
  }

  .links a svg {
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
  }

  .links a:hover {
    border-color: #8b30d0;
    color: #fff;
    background: rgba(110, 40, 180, 0.12);
    box-shadow: 0 0 20px rgba(110, 40, 180, 0.25);
  }
</style>
